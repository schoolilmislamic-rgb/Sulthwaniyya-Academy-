/* Google Font */
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@300;400;500;600&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    background:#ffffff;
    color:#222;
}

/* =======================
   Navbar
======================= */

.navbar{
    background:rgba(11,35,65,.95)!important;
    backdrop-filter:blur(12px);
    padding:15px 0;
    transition:.4s;
}

.navbar-brand h5{
    font-family:'Cinzel',serif;
    color:#fff;
    margin:0;
    font-size:22px;
}

.navbar-brand small{
    color:#d4af37;
    letter-spacing:1px;
}

.nav-link{
    color:#fff!important;
    margin-left:18px;
    font-weight:500;
}

.nav-link:hover{
    color:#d4af37!important;
}

/* =======================
   Hero Section
======================= */

.hero{
    height:100vh;
    background:
    linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.55)),
    url("../images/hero1.jpg");
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero-content h1{
    font-family:'Cinzel',serif;
    font-size:65px;
    color:#fff;
    letter-spacing:3px;
}

.hero-content p{
    color:#fff;
    font-size:20px;
    margin-top:15px;
}

.btn-warning{
    background:#d4af37;
    border:none;
    color:#fff;
    padding:12px 35px;
    border-radius:50px;
}

.btn-warning:hover{
    background:#b78d1d;
}

/* =======================
   About
======================= */

section{
    padding:90px 0;
}

h2{
    font-family:'Cinzel',serif;
    color:#0b2341;
    margin-bottom:20px;
}

#about img{
    border-radius:18px;
    box-shadow:0 10px 30px rgba(0,0,0,.15);
}

/* =======================
   Gallery
======================= */

#gallery img{
    border-radius:15px;
    transition:.4s;
    cursor:pointer;
}

#gallery img:hover{
    transform:scale(1.05);
}

/* =======================
   Contact
======================= */

#contact{
    background:#0b2341;
    color:#fff;
}

#contact h2{
    color:#fff;
}

/* =======================
   Footer
======================= */

footer{
    background:#071a30;
    color:#fff;
    text-align:center;
    padding:18px;
}

/* =======================
   Mobile
======================= */

@media(max-width:768px){

.hero-content h1{
    font-size:38px;
}

.hero-content p{
    font-size:16px;
}

.navbar-brand h5{
    font-size:18px;
}

}
